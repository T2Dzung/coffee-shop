apiVersion: v1
kind: ConfigMap
metadata:
  name: coffeeshop-config
  namespace: coffeeshop
data:
  APP_NAME_PRODUCT: "product-service"
  APP_NAME_COUNTER: "counter-service"
  APP_NAME_BARISTA: "barista-service"
  APP_NAME_KITCHEN: "kitchen-service"
  APP_NAME_PROXY: "proxy-service"
  
  GRPC_PRODUCT_HOST: "product"
  GRPC_PRODUCT_PORT: "5001"
  GRPC_COUNTER_HOST: "counter"
  GRPC_COUNTER_PORT: "5002"
  PRODUCT_CLIENT_URL: "product:5001"
  
  REVERSE_PROXY_URL: "http://proxy:5000"
  WEB_PORT: "8888"
  IN_DOCKER: "true"

---
apiVersion: v1
kind: Secret
metadata:
  name: coffeeshop-secret
  namespace: coffeeshop
type: Opaque
data:
  # PG_PASSWORD (Base64 encoded): your_db_password_here
  PG_PASSWORD: REPLACE_WITH_BASE64_PASSWORD
  # PG_URL (Base64 encoded): postgres://postgres:<password>@postgres:5432/postgres
  PG_URL: REPLACE_WITH_BASE64_PG_URL
  # PG_DSN_URL (Base64 encoded)
  PG_DSN_URL: REPLACE_WITH_BASE64_PG_DSN_URL
  
  # RABBITMQ_DEFAULT_USER (Base64 encoded)
  RABBITMQ_DEFAULT_USER: REPLACE_WITH_BASE64_RABBITMQ_USER
  # RABBITMQ_DEFAULT_PASS (Base64 encoded)
  RABBITMQ_DEFAULT_PASS: REPLACE_WITH_BASE64_RABBITMQ_PASS
  # RABBITMQ_URL (Base64 encoded)
  RABBITMQ_URL: REPLACE_WITH_BASE64_RABBITMQ_URL
